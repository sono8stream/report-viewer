{
  "hosting": {
    "public": "public",
    "cleanUrls": false,
    "ignore": ["firebase.json", "**/.*"],
    "rewrites": [
      { "source": "/",           "destination": "/reports.html" },
      { "source": "/reports",    "destination": "/reports.html" },
      { "source": "/reports/**", "function": "api" },
      { "source": "/admin",        "function": "api" },
      { "source": "/api/**",       "function": "api" },
      { "source": "/sitemap.xml",  "function": "api" }
    ]
  },
  "functions": {
    "source": ".",
    "runtime": "nodejs22"
  }
}
